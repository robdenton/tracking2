// Prisma schema for Marketing Activity Impact
// Uses SQLite locally; PostgreSQL for production on Vercel.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Activity {
  id                         String  @id @default(uuid())
  activityType               String  @map("activity_type")
  channel                    String
  partnerName                String  @map("partner_name")
  date                       String  // YYYY-MM-DD
  status                     String  @default("live") // live, booked, canceled
  costUsd                    Float?  @map("cost_usd")
  deterministicClicks        Int?    @map("deterministic_clicks")
  actualClicks               Int?    @map("actual_clicks")
  deterministicTrackedSignups Int?   @map("deterministic_tracked_signups")
  notes                      String?
  metadata                   String? @map("metadata") // JSON: channel-specific bet metrics
  contentUrl                 String? @map("content_url") // URL to the actual content (e.g. YouTube video)
  channelUrl                 String? @map("channel_url") // URL to the partner's channel
  source                     String  @default("sheets") // sheets, podscribe, manual
  tag                        String? // affiliate, paid, etc. — user-set label for filtering

  contentViews               ContentView[]
  linkedInEngagements        LinkedInEngagement[]
  uplift                     ActivityUplift?

  @@map("activities")
}

model ActivityUplift {
  activityId                       String   @id @map("activity_id")
  computedAt                       DateTime @default(now()) @map("computed_at")

  // Baseline
  baselineWindowStart              String   @map("baseline_window_start")
  baselineWindowEnd                String   @map("baseline_window_end")
  baselineAvg                      Float    @map("baseline_avg")

  // Raw uplift (before proportional attribution)
  rawIncrementalSignups            Float    @map("raw_incremental_signups")
  rawIncrementalActivations        Float    @map("raw_incremental_activations")

  // Attributed uplift (after click-share splitting — the canonical figures)
  attributedIncrementalSignups     Float    @map("attributed_incremental_signups")
  attributedIncrementalActivations Float    @map("attributed_incremental_activations")
  attributedIncrActAllDevices      Float    @default(0) @map("attributed_incr_act_all_devices")

  // Upper-bound estimates (7-day post-window)
  upperBoundIncrSignups            Float    @default(0) @map("upper_bound_incr_signups")
  upperBoundIncrActivations        Float    @default(0) @map("upper_bound_incr_activations")
  upperBoundIncrActAllDevices      Float    @default(0) @map("upper_bound_incr_act_all_devices")

  // Attribution metadata
  clicksUsed                       Int?     @map("clicks_used")
  clicksSource                     String?  @map("clicks_source") // "actual" | "deterministic" | "estimated"

  // Confidence
  confidence                       String
  confidenceExplanation            String   @map("confidence_explanation")

  // JSON blobs for detail-page display
  dailySharesJson                  String?  @map("daily_shares_json") // DailyAttributionShare[]
  dailyDataJson                    String?  @map("daily_data_json")   // DayDataPoint[]

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@map("activity_uplifts")
}

model DailyMetric {
  date                 String  // YYYY-MM-DD
  channel              String
  signups              Int
  activations          Int     // NAU desktop (primary)
  activationsAllDevices Int    @default(0) @map("activations_all_devices") // NAU all devices

  @@id([date, channel])
  @@map("daily_metrics")
}

model ContentView {
  activityId  String  @map("activity_id")
  date        String  // YYYY-MM-DD
  viewCount   Int     @map("view_count")
  activity    Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@id([activityId, date])
  @@map("content_views")
}

model LinkedInEngagement {
  activityId  String    @map("activity_id")
  date        String    // YYYY-MM-DD (tracking date)
  postDate    String?   @map("post_date") // When post was published
  likes       Int?
  comments    Int?
  reposts     Int?
  views       Int?      // Post impressions if visible
  activity    Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@id([activityId, date])
  @@map("linkedin_engagements")
}

// Imported YouTube videos that have been accepted for tracking
model ImportedYouTubeVideo {
  id              String   @id @default(uuid())
  videoId         String   @unique  // YouTube video ID (e.g., dQw4w9WgXcQ)
  title           String
  channelTitle    String   @map("channel_title")
  channelId       String   @map("channel_id")
  publishedAt     String   // YYYY-MM-DD when video was published
  url             String   // Full YouTube URL
  thumbnailUrl    String?  @map("thumbnail_url")

  importedDate    String   // YYYY-MM-DD when imported into system
  status          String   @default("active") // active, archived
  source          String   @default("organic") // organic, paid_sponsorship, paid_ad

  // Optional: link to Activity if this becomes a paid sponsorship
  relatedActivityId String?  @map("related_activity_id")

  // YouTube API metadata (fetched once at import / backfilled)
  description      String?  // Full video description
  durationSeconds  Int?     @map("duration_seconds")
  likeCount        Int?     @map("like_count")
  commentCount     Int?     @map("comment_count")

  // Description analysis (parsed from description text)
  granolaLinkInDesc   Boolean? @map("granola_link_in_desc")
  granolaLinkType     String?  @map("granola_link_type")    // "direct" | "tracked" | "none"
  sponsoredDisclosure Boolean? @map("sponsored_disclosure") // #ad / "sponsored by" in description

  // Transcript / content analysis (populated by LLM analysis pipeline later)
  transcriptText        String?   @map("transcript_text")        // Raw transcript (stored to avoid re-scraping supadata)
  depthScore            Float?    @map("depth_score")            // 0–1 composite
  depthTier             String?   @map("depth_tier")             // dedicated | featured | listed | incidental
  contentType           String?   @map("content_type")           // tutorial | review | comparison | listicle | interview | podcast | other
  creatorPersonallyUses Boolean?  @map("creator_personally_uses")
  explicitCta           Boolean?  @map("explicit_cta")
  granolaMinutes        Float?    @map("granola_minutes")
  firstMentionPct       Int?      @map("first_mention_pct")      // 0–100, where in video Granola first appears
  mentionCount          Int?      @map("mention_count")
  sentiment             String?                                   // positive | neutral | mixed
  competitorsMentioned  String?   @map("competitors_mentioned")  // JSON array of competitor names
  targetAudience        String?   @map("target_audience")        // founders | knowledge_workers | general_tech | students | other
  transcriptAvailable   Boolean?  @map("transcript_available")
  contentAnalysedAt     DateTime? @map("content_analysed_at")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  importedVideoViews ImportedVideoView[]

  @@map("imported_youtube_videos")
}

// Time-series view tracking for imported videos (follows ContentView pattern)
model ImportedVideoView {
  videoId    String  @map("video_id")
  date       String  // YYYY-MM-DD
  viewCount  Int     @map("view_count")
  video      ImportedYouTubeVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([videoId, date])
  @@map("imported_video_views")
}

// Search results waiting for user review (accept/reject)
model YouTubeSearchResult {
  id              String   @id @default(uuid())
  videoId         String   @map("video_id")
  title           String
  channelTitle    String   @map("channel_title")
  channelId       String   @map("channel_id")
  publishedAt     String   // YYYY-MM-DD
  url             String
  thumbnailUrl    String?  @map("thumbnail_url")
  description     String?  // Video description snippet

  searchQuery     String   @map("search_query") // e.g., "granola ai"
  searchDate      String   @map("search_date")  // YYYY-MM-DD when found
  status          String   @default("pending")  // pending, accepted, rejected

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([videoId, searchQuery]) // Prevent duplicate search results
  @@map("youtube_search_results")
}

// LinkedIn company content analysis
model LinkedInCompany {
  id          String   @id @default(uuid())
  slug        String   @unique // e.g. "linearapp"
  name        String?  // e.g. "Linear"
  linkedinUrl String   @map("linkedin_url")
  scrapedAt   DateTime @map("scraped_at")

  posts LinkedInCompanyPost[]

  @@map("linkedin_companies")
}

model LinkedInCompanyPost {
  id                String  @id @default(uuid())
  companyId         String  @map("company_id")
  postText          String  @map("post_text")
  postDate          String? @map("post_date") // YYYY-MM-DD
  postUrl           String? @map("post_url")
  likes             Int?
  comments          Int?
  reposts           Int?
  views             Int?
  category          String?
  categoryReasoning String? @map("category_reasoning")

  company LinkedInCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("linkedin_company_posts")
}

// Dub.co per-link daily click data — one row per link per day
// Used to cross-reference against sheet-reported actualClicks on activities
model DubLinkDaily {
  id        String   @id @default(uuid())
  shortLink String   @map("short_link")  // e.g. https://go.granola.ai/efficient
  url       String?                       // destination URL (for reference)
  date      String                        // YYYY-MM-DD
  clicks    Int      @default(0)
  leads     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([shortLink, date])
  @@index([shortLink])
  @@index([date])
  @@map("dub_link_daily")
}

// Dub partner group metadata (tags, labels)
model DubGroupMeta {
  groupId   String   @id @map("group_id") // Dub group ID
  tag       String?  // affiliate, influencer, etc.
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("dub_group_meta")
}

// Cached partner data from Dub API — refreshed daily by sync-dub cron
model DubPartnerCache {
  dubPartnerId     String   @id @map("dub_partner_id")
  name             String
  groupId          String?  @map("group_id")
  groupName        String?  @map("group_name")
  totalClicks      Int      @default(0) @map("total_clicks")
  totalLeads       Int      @default(0) @map("total_leads")
  totalConversions Int      @default(0) @map("total_conversions")
  totalCommissions Float    @default(0) @map("total_commissions")
  totalSaleAmount  Float    @default(0) @map("total_sale_amount")
  clickToLeadRate  Float    @default(0) @map("click_to_lead_rate")
  leadToConvRate   Float    @default(0) @map("lead_to_conv_rate")
  shortLinks       String[] @map("short_links") // Array of shortLink URLs
  syncedAt         DateTime @default(now()) @map("synced_at")

  @@map("dub_partner_cache")
}

// Maps a Dub short link to a newsletter partner name
// One Dub link per partner (used across all their placements)
model DubNewsletterMapping {
  id          String   @id @default(uuid())
  shortLink   String   @unique @map("short_link") // e.g. https://go.granola.ai/tldr
  partnerName String   @map("partner_name")       // matches activities.partner_name
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("dub_newsletter_mappings")
}

// Pipeline execution log — records each cron job run
model CronExecution {
  id            String    @id @default(uuid())
  taskName      String    @map("task_name")   // "sync-sheets", "track-youtube", etc.
  startedAt     DateTime  @map("started_at")
  completedAt   DateTime? @map("completed_at")
  status        String    // "running", "success", "error"
  resultJson    String?   @map("result_json") // JSON blob of task result counts
  errorMessage  String?   @map("error_message")

  @@index([taskName, startedAt])
  @@map("cron_executions")
}

// NextAuth.js authentication models
model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts        Account[]
  sessions        Session[]
  unipileAccounts UnipileLinkedInAccount[]

  @@map("users")
}

// Employee LinkedIn account connected via Unipile
// Google Ads — per-click data via the ClickView API
// Each row = one ad click identified by its GCLID.
// 90-day API window (clicks older than 90 days are unavailable).
model GoogleAdsClick {
  gclid                String   @id @map("gclid")
  clickDate            String   @map("click_date") // YYYY-MM-DD (segments.date)
  customerId           String   @map("customer_id")
  campaignId           String   @map("campaign_id")
  campaignName         String?  @map("campaign_name")
  campaignChannelType  String?  @map("campaign_channel_type") // SEARCH | DEMAND_GEN | PERFORMANCE_MAX | DISPLAY | etc.
  adGroupId            String?  @map("ad_group_id")
  adGroupName          String?  @map("ad_group_name")
  adGroupAdId          String?  @map("ad_group_ad_id")
  adNetworkType        String?  @map("ad_network_type") // SEARCH | YOUTUBE | DISPLAY | etc.
  device               String?  @map("device") // DESKTOP | MOBILE | TABLET | etc.
  keywordText          String?  @map("keyword_text")
  keywordMatchType     String?  @map("keyword_match_type")
  areaOfInterestId     String?  @map("area_of_interest_id")
  locationOfPresenceId String?  @map("location_of_presence_id")
  userListId           String?  @map("user_list_id")
  pageNumber           Int?     @map("page_number")
  discoveredAt         DateTime @default(now()) @map("discovered_at")
  lastSeenAt           DateTime @default(now()) @map("last_seen_at")

  @@index([clickDate])
  @@index([campaignId])
  @@index([campaignChannelType])
  @@index([adNetworkType])
  @@map("google_ads_clicks")
}

// Granola users imported from product DB / Omni — used to join GCLIDs against
// google_ads_clicks for attribution recovery on users whose UTMs were lost.
model GranolaUser {
  userId         String   @id @map("user_id")
  email          String?
  signedUpAt     DateTime @map("signed_up_at")
  gclid          String?
  utmSource      String?  @map("utm_source")
  utmCampaign    String?  @map("utm_campaign")
  utmMedium      String?  @map("utm_medium")
  utmContent     String?  @map("utm_content")
  utmTerm        String?  @map("utm_term")
  referrer       String?
  // Lifecycle markers (optional, populated if available — useful for LTV joins)
  firstActivatedAt DateTime? @map("first_activated_at")
  becamePayingAt   DateTime? @map("became_paying_at")
  importedAt     DateTime @default(now()) @map("imported_at")
  lastSeenAt     DateTime @default(now()) @map("last_seen_at")

  @@index([gclid])
  @@index([signedUpAt])
  @@index([utmSource])
  @@map("granola_users")
}

// X (Twitter) — brand mentions of Granola
model XMention {
  tweetId             String    @id @map("tweet_id")
  conversationId      String?   @map("conversation_id")
  inReplyToTweetId    String?   @map("in_reply_to_tweet_id")
  text                String
  lang                String?
  postedAt            DateTime  @map("posted_at")

  // Author
  authorId            String    @map("author_id")
  authorUsername      String?   @map("author_username")
  authorName          String?   @map("author_name")
  authorVerified      Boolean?  @map("author_verified")
  authorFollowers     Int?      @map("author_followers")

  // Public metrics (snapshotted at last fetch — accumulate over time)
  impressionCount     Int       @default(0) @map("impression_count")
  likeCount           Int       @default(0) @map("like_count")
  retweetCount        Int       @default(0) @map("retweet_count")
  replyCount          Int       @default(0) @map("reply_count")
  quoteCount          Int       @default(0) @map("quote_count")
  bookmarkCount       Int       @default(0) @map("bookmark_count")

  // LLM classification: is this tweet about Granola the AI product, granola the food,
  // or ambiguous?
  llmClassification   String?   @map("llm_classification") // "product" | "food" | "ambiguous"
  llmReasoning        String?   @map("llm_reasoning")
  llmClassifiedAt     DateTime? @map("llm_classified_at")

  excluded            Boolean   @default(false) // manual hide for false positives
  discoveredAt        DateTime  @default(now()) @map("discovered_at")
  lastSeenAt          DateTime  @default(now()) @map("last_seen_at")

  @@index([postedAt])
  @@index([llmClassification])
  @@index([excluded])
  @@index([impressionCount])
  @@map("x_mentions")
}

// Podscan.fm — organic podcast mentions of Granola across all podcasts
model PodscanMention {
  episodeId           String   @id @map("episode_id") // Podscan episode_id (e.g. ep_xxx)
  podcastId           String   @map("podcast_id") // Podscan podcast_id (e.g. pd_xxx)
  podcastName         String?  @map("podcast_name")
  podcastReach        Int?     @map("podcast_reach") // Podscan reach score (0-100 proprietary index)
  podcastAudienceSize Int?     @map("podcast_audience_size") // Estimated per-episode listeners from Podscan
  episodeTitle        String?  @map("episode_title")
  episodeUrl          String?  @map("episode_url")
  episodeAudioUrl     String?  @map("episode_audio_url")
  postedAt            String?  @map("posted_at") // ISO datetime
  durationSec         Int?     @map("duration_sec")
  isSponsored         Boolean? @map("is_sponsored") // from metadata.is_branded
  sponsoredScore      Float?   @map("sponsored_score") // is_branded_confidence_score
  sponsoredReason     String?  @map("sponsored_reason") // is_branded_confidence_reason
  summaryShort        String?  @map("summary_short")
  summaryLong         String?  @map("summary_long")
  sentimentLabel      String?  @map("sentiment_label")
  sentimentScore      Float?   @map("sentiment_score")
  matchedQuery        String?  @map("matched_query") // first matching query (legacy)
  matchedQueries      String?  @map("matched_queries") // comma-separated list of all matching queries
  confidenceTier      String?  @default("medium") @map("confidence_tier") // "high" | "medium"
  snippets            String?  // transcript context around each "granola" mention (~1000 chars)
  llmClassification   String?  @map("llm_classification") // "product" | "food" | "ambiguous"
  llmReasoning        String?  @map("llm_reasoning")
  llmClassifiedAt     DateTime? @map("llm_classified_at")
  excluded            Boolean  @default(false) // manual hide for false positives
  discoveredAt        DateTime @default(now()) @map("discovered_at")
  lastSeenAt          DateTime @default(now()) @map("last_seen_at")

  @@index([postedAt])
  @@index([isSponsored])
  @@index([excluded])
  @@map("podscan_mentions")
}

model UnipileLinkedInAccount {
  id               String    @id @default(uuid())
  userId           String?   @map("user_id")
  teamMemberName   String?   @map("team_member_name") // For public connect flow (no app user)
  unipileAccountId String    @unique @map("unipile_account_id")
  linkedinId       String?   @map("linkedin_id")       // LinkedIn internal ID (e.g. ACoAAASi_3sB...)
  linkedinName     String?   @map("linkedin_name")
  status           String    @default("pending") // pending | connected | disconnected
  connectedAt      DateTime? @map("connected_at")
  lastSyncAt       DateTime? @map("last_sync_at")
  lastSyncError    String?   @map("last_sync_error")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user  User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts EmployeeLinkedInPost[]

  @@map("unipile_linkedin_accounts")
}

// Company LinkedIn page post (synced via Unipile API)
model CompanyLinkedInPost {
  id            String   @id @default(uuid())
  socialId      String   @unique @map("social_id") // Unipile post ID
  postText      String?  @map("post_text")
  postDate      String   @map("post_date") // YYYY-MM-DD
  shareUrl      String?  @map("share_url")
  impressions   Int      @default(0)
  reactions     Int      @default(0)
  comments      Int      @default(0)
  reposts       Int      @default(0)
  lastFetchedAt DateTime @map("last_fetched_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([postDate])
  @@map("company_linkedin_posts")
}

// Individual LinkedIn post from a connected employee
model EmployeeLinkedInPost {
  id            String   @id @default(uuid())
  accountId     String   @map("account_id")
  socialId      String   @map("social_id")
  postText      String?  @map("post_text")
  postDate      String   @map("post_date") // YYYY-MM-DD
  shareUrl      String?  @map("share_url")
  impressions   Int      @default(0)
  reactions     Int      @default(0)
  comments      Int      @default(0)
  reposts       Int      @default(0)
  lastFetchedAt DateTime @map("last_fetched_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  account UnipileLinkedInAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, socialId])
  @@index([postDate])
  @@map("employee_linkedin_posts")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// LinkedIn Ads API connection (org-level, one admin connects)
model LinkedInAdsConnection {
  id            String    @id @default(uuid())
  accessToken   String    @map("access_token")
  refreshToken  String?   @map("refresh_token")
  expiresAt     DateTime  @map("expires_at")
  adAccountId   String?   @map("ad_account_id")   // Sponsored account URN e.g. "urn:li:sponsoredAccount:123"
  adAccountName String?   @map("ad_account_name")
  connectedBy   String    @map("connected_by")     // user email who connected
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("linkedin_ads_connections")
}

// LinkedIn ad campaign metadata
model LinkedInAdCampaign {
  id              String   @id @default(uuid())
  campaignUrn     String   @unique @map("campaign_urn") // "urn:li:sponsoredCampaign:123"
  name            String
  status          String   // ACTIVE, PAUSED, ARCHIVED, COMPLETED, CANCELED, DRAFT
  type            String?  // TEXT_AD, SPONSORED_UPDATES, SPONSORED_INMAILS, etc.
  costType        String?  @map("cost_type") // CPC, CPM, CPV
  dailyBudget     Float?   @map("daily_budget")
  totalBudget     Float?   @map("total_budget")
  campaignGroupId String?  @map("campaign_group_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  dailyStats LinkedInAdDaily[]
  creatives  LinkedInAdCreative[]

  @@map("linkedin_ad_campaigns")
}

// Cached LinkedIn org ID → company name (resolved via Unipile)
model LinkedInOrgNameCache {
  orgId     String   @id @map("org_id") // LinkedIn organization numeric ID
  name      String?  // Resolved company name (null if lookup failed)
  resolved  Boolean  @default(false) // true once lookup attempted
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("linkedin_org_name_cache")
}

// Daily ad performance metrics per campaign
model LinkedInAdDaily {
  id                String  @id @default(uuid())
  campaignId        String  @map("campaign_id")
  date              String  // YYYY-MM-DD
  impressions       Int     @default(0)
  clicks            Int     @default(0)
  spend             Float   @default(0) // costInLocalCurrency
  landingPageClicks Int     @default(0) @map("landing_page_clicks")
  reactions         Int     @default(0) // socialReactions (likes)
  comments          Int     @default(0)
  shares            Int     @default(0)
  follows           Int     @default(0)
  conversions       Int     @default(0)
  costPerClick      Float?  @map("cost_per_click")

  campaign LinkedInAdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([date])
  @@map("linkedin_ad_daily")
}

// LinkedIn ad creative metadata
model LinkedInAdCreative {
  id              String   @id @default(uuid())
  creativeUrn     String   @unique @map("creative_urn") // "urn:li:sponsoredCreative:123"
  campaignId      String   @map("campaign_id")
  name            String?
  intendedStatus  String?  @map("intended_status") // ACTIVE, PAUSED, DRAFT, ARCHIVED
  contentRef      String?  @map("content_ref") // content.reference URN (shared = same asset)
  isServing       Boolean  @default(false) @map("is_serving")
  createdBy       String?  @map("created_by") // "urn:li:person:XXX" who created this creative
  creatorName     String?  @map("creator_name") // resolved display name of the creator
  apiCreatedAt    DateTime? @map("api_created_at") // creation timestamp from LinkedIn API
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  campaign   LinkedInAdCampaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  dailyStats LinkedInAdCreativeDaily[]

  @@map("linkedin_ad_creatives")
}

// Daily ad performance metrics per creative
model LinkedInAdCreativeDaily {
  id                String  @id @default(uuid())
  creativeId        String  @map("creative_id")
  date              String  // YYYY-MM-DD
  impressions       Int     @default(0)
  clicks            Int     @default(0)
  spend             Float   @default(0)
  landingPageClicks Int     @default(0) @map("landing_page_clicks")
  reactions         Int     @default(0)
  comments          Int     @default(0)
  shares            Int     @default(0)
  follows           Int     @default(0)
  conversions       Int     @default(0)
  costPerClick      Float?  @map("cost_per_click")

  creative LinkedInAdCreative @relation(fields: [creativeId], references: [id], onDelete: Cascade)

  @@unique([creativeId, date])
  @@index([date])
  @@map("linkedin_ad_creative_daily")
}

// ---------------------------------------------------------------------------
// Podscribe podcast attribution
// ---------------------------------------------------------------------------

model PodscribeCampaign {
  id              String   @id @default(uuid())
  campaignId      String   @unique @map("campaign_id") // Podscribe campaign internal ID
  name            String   // Campaign name
  publisher       String   // e.g. "YAP Media", "Vox Media"
  show            String   // Show name
  type            String?  // "baked-in" or "dai"
  tags            String?
  startDate       String?  @map("start_date")
  expectedDate    String?  @map("expected_date")
  endDate         String?  @map("end_date")
  totalSpend      Float    @default(0) @map("total_spend") // Accumulated from daily data
  totalImpressions Int     @default(0) @map("total_impressions")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  dailyStats PodscribeCampaignDaily[]

  @@map("podscribe_campaigns")
}

model PodscribeCampaignDaily {
  id              String  @id @default(uuid())
  campaignId      String  @map("campaign_id")
  date            String  // YYYY-MM-DD
  impressions     Int     @default(0) // Podcast & Streaming Impressions
  reach           Int     @default(0)
  spend           Float   @default(0)
  visitors        Float   @default(0)
  visits          Float   @default(0)

  campaign PodscribeCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([date])
  @@map("podscribe_campaign_daily")
}

// ---------------------------------------------------------------------------
// UGC / Growi
// ---------------------------------------------------------------------------

// Daily snapshot from Growi API (aggregated across all creators)
model GrowiDailySnapshot {
  id              String   @id @default(uuid())
  date            String   @unique // YYYY-MM-DD
  views           Int      @default(0)
  likes           Int      @default(0)
  comments        Int      @default(0)
  shares          Int      @default(0)
  saves           Int      @default(0)
  postsCount      Int      @default(0) @map("posts_count")
  tiktokViews     Int      @default(0) @map("tiktok_views")
  tiktokLikes     Int      @default(0) @map("tiktok_likes")
  tiktokComments  Int      @default(0) @map("tiktok_comments")
  tiktokShares    Int      @default(0) @map("tiktok_shares")
  tiktokSaves     Int      @default(0) @map("tiktok_saves")
  tiktokPosts     Int      @default(0) @map("tiktok_posts")
  instagramViews  Int      @default(0) @map("instagram_views")
  instagramLikes  Int      @default(0) @map("instagram_likes")
  instagramComments Int    @default(0) @map("instagram_comments")
  instagramShares Int      @default(0) @map("instagram_shares")
  instagramSaves  Int      @default(0) @map("instagram_saves")
  instagramPosts  Int      @default(0) @map("instagram_posts")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([date])
  @@map("growi_daily_snapshots")
}

// ---------------------------------------------------------------------------
// Dub Customer Attribution
// ---------------------------------------------------------------------------

// Maps Dub customers (with externalId = Granola user UUID) to partner links
model DubCustomer {
  id              String   @id @default(uuid())
  dubCustomerId   String   @unique @map("dub_customer_id") // e.g. cus_1KMQ60F5T3Q69JEBSFGC9WDXC
  externalId      String   @map("external_id") // Granola user UUID
  country         String?
  linkKey         String?  @map("link_key") // e.g. "francesco-d-alessio"
  linkDomain      String?  @map("link_domain") // e.g. "go.granola.ai"
  shortLink       String?  @map("short_link") // e.g. "https://go.granola.ai/francesco-d-alessio"
  partnerId       String?  @map("partner_id") // Dub partner ID
  partnerName     String?  @map("partner_name") // Resolved partner name
  groupId         String?  @map("group_id") // Dub group ID
  groupName       String?  @map("group_name") // Resolved group name
  dubCreatedAt    DateTime? @map("dub_created_at") // When the customer was created in Dub
  syncedAt        DateTime @default(now()) @map("synced_at")

  @@index([externalId])
  @@index([partnerId])
  @@index([groupId])
  @@map("dub_customers")
}
